# VidPort Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=vidport
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_strong_password

# ── MinIO (S3-compatible storage) ────────────────────────────────────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change_me_strong_password

# ── JWT Authentication ────────────────────────────────────────────────────────
# Must be at least 32 characters long
JWT_SECRET_KEY=change_me_min_32_chars_long_secret_key_here

# ── CORS ─────────────────────────────────────────────────────────────────────
# Semicolon-separated list of allowed frontend origins
# For production: https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Job Scraper (Adzuna API) ──────────────────────────────────────────────────
# Get keys at: https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── AI Insights ───────────────────────────────────────────────────────────────
# Get key at: https://platform.openai.com
OPENAI_API_KEY=

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3001
