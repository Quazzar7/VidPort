{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5434;Database=vidport;Username=admin;Password=password"
  },
  "JwtOptions": {
    "SecretKey": "super-secret-key-that-should-be-at-least-32-characters-long",
    "Issuer": "VidPort",
    "Audience": "VidPort",
    "AccessTokenExpirationMinutes": 15
  },
  "S3Options": {
    "ServiceUrl": "http://localhost:9000",
    "AccessKey": "admin",
    "SecretKey": "password",
    "RawBucketName": "vidport-raw",
    "ForcePathStyle": true
  }
}
